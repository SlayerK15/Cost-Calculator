# ============================================================
# LLM Cloud Platform — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env with real secrets.
# ============================================================

# ── Core ──
DEBUG=true                                           # Set false in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ──
POSTGRES_PASSWORD=change-me-strong-password          # Used by docker-compose
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@localhost:5432/llmplatform
DATABASE_URL_SYNC=postgresql://postgres:change-me-strong-password@localhost:5432/llmplatform

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Auth (REQUIRED — generate with: openssl rand -hex 32) ──
SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32

# ── Credential Encryption (REQUIRED for production) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# ── Stripe (payment gateway) ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx
FRONTEND_URL=http://localhost:3000

# ── Hugging Face ──
HF_TOKEN=hf_your_token_here

# ── AI Agent ──
AGENT_LLM_PROVIDER=openai
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=gpt-4o-mini

# ── n8n Workflow ──
N8N_WEBHOOK_URL=http://localhost:5678/webhook/autonomous-llm-builder
N8N_CALLBACK_SECRET=change-me-n8n-callback-secret    # Generate with: openssl rand -hex 16
N8N_USER=admin
N8N_PASSWORD=change-me-n8n-password
