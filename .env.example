# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llmplatform
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/llmplatform

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Auth ──
SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32

# ── Stripe (payment gateway) ──
STRIPE_SECRET_KEY=sk_test_xxx                    # From Stripe Dashboard → API Keys
STRIPE_WEBHOOK_SECRET=whsec_xxx                  # From Stripe CLI or Dashboard → Webhooks
STRIPE_PRO_PRICE_ID=price_xxx                    # Price ID for Pro $49/mo product
STRIPE_ENTERPRISE_PRICE_ID=price_xxx             # Price ID for Enterprise $199/mo product
FRONTEND_URL=http://localhost:3000

# ── Hugging Face ──
HF_TOKEN=hf_your_token_here

# ── AWS (for deployment) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── GCP (for deployment) ──
GCP_PROJECT_ID=
GCP_CREDENTIALS_JSON=

# ── Azure (for deployment) ──
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
