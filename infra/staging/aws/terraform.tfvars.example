# Copy this to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

# REQUIRED: Your SSH key pair name (must already exist in AWS)
# Create one: aws ec2 create-key-pair --key-name llm-staging --query 'KeyMaterial' --output text > ~/.ssh/llm-staging.pem && chmod 600 ~/.ssh/llm-staging.pem
ec2_key_name = "llm-staging"

# Optional: Lock SSH to your IP for security
# Find your IP: curl -s ifconfig.me
# allowed_ssh_cidr = "1.2.3.4/32"

# Optional: Change region
# region = "us-east-1"

# Optional: Change instance sizes
# ec2_instance_type = "t3.medium"   # App server (~$30/mo)
# db_instance_class = "db.t3.micro" # RDS Postgres (~$13/mo)
# redis_node_type   = "cache.t3.micro" # ElastiCache (~$12/mo)
